# WhatsApp Business API endpoint
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/YOUR_PHONE_NUMBER_ID/messages

# Bearer token for WhatsApp Business API
WHATSAPP_API_TOKEN=YOUR_ACCESS_TOKEN

# Optional: phone number to receive the WhatsApp message (international format without +)
WHATSAPP_PHONE=255769604606

# Optional: public site URL used for uploaded artwork links, for example https://boldprints.co.ke
WHATSAPP_PUBLIC_BASE_URL=
