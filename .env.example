# Use Meta WhatsApp Cloud API for direct document/file sending
WHATSAPP_PROVIDER=meta
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID

# Bearer token for WhatsApp Business API / Meta Cloud API
WHATSAPP_API_TOKEN=YOUR_ACCESS_TOKEN

# Optional: phone number to receive the WhatsApp message (international format without +)
WHATSAPP_PHONE=255769604606

# Optional: public site URL used for Twilio media and link fallback, for example https://boldprints.co.ke
WHATSAPP_PUBLIC_BASE_URL=

# Optional: custom direct-send endpoint if you are not using Meta or Twilio
WHATSAPP_API_URL=
